# SentinelRecon Configuration File
# Copy this to .env and fill in your API keys

# Claude API Configuration
CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI API Configuration (optional alternative to Claude)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo

# NVD API Configuration (optional but recommended for CVE lookups)
NVD_API_KEY=your_nvd_api_key_here

# Database Configuration
DATABASE_PATH=~/.sentinelrecon/sentinel.db
LOG_PATH=~/.sentinelrecon/logs/sentinel.log

# Application Settings
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Scan Defaults
DEFAULT_SCAN_TIMEOUT=5
DEFAULT_THREAD_COUNT=10
DEFAULT_PORTS=1-1024

# AI Provider (claude or openai)
AI_PROVIDER=claude

# Beginner Mode (True for simplified explanations)
BEGINNER_MODE=True
